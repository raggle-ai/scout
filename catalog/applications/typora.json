{
  "name": "Typora",
  "slug": "typora",
  "category": "Application",
  "homepage": "https://typora.io/",
  "platforms": ["macOS", "Windows", "Linux"],
  "appNames": ["Typora.app"],
  "capabilities": {
    "opensProjectFolder": true,
    "canResumeProjectSession": false,
    "canStartNewProjectSession": false
  },
  "launchers": [
    {
      "id": "open-folder-command",
      "label": "Open folder",
      "kind": "command",
      "intent": "open-folder",
      "urlTemplate": "open -a Typora {absolutePath}",
      "variables": [
        {
          "key": "absolutePath",
          "label": "Project folder",
          "placeholder": "/Users/you/project",
          "format": "absolute-path",
          "encoding": "none"
        }
      ]
    }
  ],
  "docs": [
    {
      "label": "Support",
      "url": "https://support.typora.io/"
    }
  ]
}
