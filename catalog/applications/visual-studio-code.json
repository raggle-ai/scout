{
  "name": "Visual Studio Code",
  "slug": "visual-studio-code",
  "category": "Application",
  "homepage": "https://code.visualstudio.com/",
  "platforms": ["macOS", "Windows", "Linux"],
  "appNames": ["Visual Studio Code.app"],
  "bundleId": "com.microsoft.VSCode",
  "capabilities": {
    "opensProjectFolder": true,
    "canResumeProjectSession": false,
    "canStartNewProjectSession": false
  },
  "launchers": [
    {
      "id": "open-folder-command",
      "label": "Open folder",
      "kind": "command",
      "intent": "open-folder",
      "urlTemplate": "code {absolutePath}",
      "variables": [
        {
          "key": "absolutePath",
          "label": "Project folder",
          "placeholder": "/Users/you/project",
          "format": "absolute-path",
          "encoding": "none"
        }
      ]
    }
  ],
  "docs": [
    {
      "label": "Command line",
      "url": "https://code.visualstudio.com/docs/editor/command-line"
    }
  ]
}
