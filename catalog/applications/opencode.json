{
  "name": "OpenCode",
  "slug": "opencode",
  "category": "Application",
  "homepage": "https://opencode.ai/",
  "platforms": ["macOS", "Windows", "Linux"],
  "appNames": ["OpenCode.app", "OpenCode Beta.app"],
  "capabilities": {
    "opensProjectFolder": true,
    "canResumeProjectSession": true,
    "canStartNewProjectSession": true
  },
  "launchers": [
    {
      "id": "open-project-command",
      "label": "Open project from terminal",
      "kind": "command",
      "intent": "fallback",
      "urlTemplate": "cd {absolutePath} && opencode",
      "variables": [
        {
          "key": "absolutePath",
          "label": "Project folder",
          "placeholder": "/Users/you/project",
          "format": "absolute-path",
          "encoding": "none"
        }
      ]
    },
    {
      "id": "run-prompt-command",
      "label": "Run prompt from terminal",
      "kind": "command",
      "intent": "new-session",
      "urlTemplate": "opencode run --dir {absolutePath} {prompt}",
      "variables": [
        {
          "key": "absolutePath",
          "label": "Project folder",
          "placeholder": "/Users/you/project",
          "format": "absolute-path",
          "encoding": "none"
        },
        {
          "key": "prompt",
          "label": "Prompt",
          "placeholder": "Investigate the failing tests",
          "format": "string",
          "encoding": "none"
        }
      ]
    }
  ],
  "docs": [
    {
      "label": "Documentation",
      "url": "https://opencode.ai/docs"
    }
  ]
}
