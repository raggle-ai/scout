---
import catalog from "../../../catalog.json";

const collectionLabels = {
  credentials: "Credentials",
  aiClients: "AI Clients",
  dashboards: "Dashboards",
  docs: "Docs",
  recipes: "Recipes",
};

const collectionEntries = Object.entries(catalog.collections);
const records = collectionEntries.flatMap(([collection, items]) =>
  items.map((item) => ({ ...item, collection })),
);
const populatedCollections = collectionEntries.filter(([, items]) => items.length > 0);
const credentialCount = catalog.collections.credentials.length;
const aiClientCount = catalog.collections.aiClients.length;

function displayUrl(item) {
  return item.domain ?? new URL(item.homepage ?? item.url).hostname;
}

function primaryHref(item) {
  return item.url ?? item.homepage;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Raggle Scout is a friendly map for developer tools, credentials pages, AI-client launchers, dashboards, docs, and setup paths."
    />
    <title>Raggle Scout</title>
  </head>
  <body>
    <header class="topbar">
      <a class="brand" href="/" aria-label="Raggle Scout home">
        <span class="brand-mark">RS</span>
        <span>
          <strong>Raggle Scout</strong>
          <small>A friendly map for developer tools and AI workflows.</small>
        </span>
      </a>

      <nav class="actions" aria-label="Catalog endpoints">
        <a href="/api.json">Credentials API</a>
        <a href="/catalog.json">Catalog API</a>
      </nav>
    </header>

    <main>
      <section class="intro" aria-labelledby="page-title">
        <div>
          <h1 id="page-title">Find the right place to go.</h1>
          <p>
            Find credential pages, AI-client launchers, dashboards, docs, and setup paths
            without hunting through settings.
          </p>
        </div>

        <dl class="stats" aria-label="Catalog summary">
          <div>
            <dt>{credentialCount}</dt>
            <dd>credentials</dd>
          </div>
          <div>
            <dt>{aiClientCount}</dt>
            <dd>AI clients</dd>
          </div>
          <div>
            <dt>{records.length}</dt>
            <dd>records</dd>
          </div>
        </dl>
      </section>

      <section class="directory" aria-labelledby="directory-title">
        <div class="directory-head">
          <h2 id="directory-title">Catalog</h2>
          <label class="search">
            <span>Search</span>
            <input
              id="search"
              type="search"
              placeholder="OpenAI, Cursor, payments, docs..."
              autocomplete="off"
            />
          </label>
        </div>

        <div class="filters" aria-label="Filter by collection">
          <button class="filter is-active" type="button" data-collection="all">All</button>
          {
            populatedCollections.map(([collection, items]) => (
              <button class="filter" type="button" data-collection={collection}>
                {collectionLabels[collection]} <span>{items.length}</span>
              </button>
            ))
          }
        </div>

        <div class="grid" id="catalog-grid">
          {
            records.map((item) => (
              <article
                class="catalog-card"
                data-collection={item.collection}
                data-search={`${item.name} ${item.category ?? ""} ${item.domain ?? ""} ${item.homepage ?? ""} ${item.url ?? ""} ${(item.platforms ?? []).join(" ")} ${(item.appNames ?? []).join(" ")} ${(item.deeplinks ?? []).map((deeplink) => `${deeplink.id ?? ""} ${deeplink.label} ${deeplink.intent ?? ""} ${deeplink.urlTemplate}`).join(" ")} ${(item.launchers ?? []).map((launcher) => `${launcher.id ?? ""} ${launcher.label} ${launcher.intent ?? ""} ${launcher.kind} ${launcher.urlTemplate}`).join(" ")} ${(item.docs ?? []).map((doc) => `${doc.label} ${doc.url}`).join(" ")}`.toLowerCase()}
              >
                <div class="card-main">
                  <img
                    src={`https://www.google.com/s2/favicons?domain=${displayUrl(item)}&sz=64`}
                    alt=""
                    width="36"
                    height="36"
                    loading="lazy"
                  />
                  <div>
                    <span class="eyebrow">{collectionLabels[item.collection]}</span>
                    <h3>{item.name}</h3>
                    <p>{item.category ?? displayUrl(item)}</p>
                  </div>
                </div>

                {
                  (item.platforms || item.appNames) && (
                    <ul class="chips" aria-label={`${item.name} metadata`}>
                      {[...(item.platforms ?? []), ...(item.appNames ?? [])].map((platform) => (
                        <li>{platform}</li>
                      ))}
                    </ul>
                  )
                }

                {
                  item.capabilities && (
                    <ul class="chips capability-chips" aria-label={`${item.name} capabilities`}>
                      {item.capabilities.opensProjectFolder && <li>Project folders</li>}
                      {item.capabilities.canResumeProjectSession && <li>Resume sessions</li>}
                      {item.capabilities.canStartNewProjectSession && <li>New sessions</li>}
                    </ul>
                  )
                }

                {
                  item.deeplinks && (
                    <div class="template-list">
                      {item.deeplinks.map((deeplink) => (
                        <div class="template-item">
                          <span>
                            {deeplink.label}
                            {deeplink.intent && <small>{deeplink.intent}</small>}
                          </span>
                          <code>{deeplink.urlTemplate}</code>
                          {deeplink.variables && (
                            <dl>
                              {deeplink.variables.map((variable) => (
                                <>
                                  <dt>{variable.label}</dt>
                                  <dd>
                                    {variable.placeholder}
                                    {variable.encoding && <small>{variable.encoding}</small>}
                                  </dd>
                                </>
                              ))}
                            </dl>
                          )}
                        </div>
                      ))}
                    </div>
                  )
                }

                {
                  item.launchers && (
                    <div class="template-list">
                      {item.launchers.map((launcher) => (
                        <div class="template-item">
                          <span>
                            {launcher.label}
                            {launcher.intent && <small>{launcher.intent}</small>}
                          </span>
                          <code>{launcher.urlTemplate}</code>
                          {launcher.variables && (
                            <dl>
                              {launcher.variables.map((variable) => (
                                <>
                                  <dt>{variable.label}</dt>
                                  <dd>
                                    {variable.placeholder}
                                    {variable.encoding && <small>{variable.encoding}</small>}
                                  </dd>
                                </>
                              ))}
                            </dl>
                          )}
                        </div>
                      ))}
                    </div>
                  )
                }

                <div class="card-actions">
                  <a href={primaryHref(item)} target="_blank" rel="noreferrer">
                    Open
                    <svg aria-hidden="true" viewBox="0 0 24 24">
                      <path
                        d="M7 17 17 7m0 0H8m9 0v9"
                        fill="none"
                        stroke="currentColor"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                      />
                    </svg>
                  </a>
                  {
                    item.docs?.map((doc) => (
                      <a href={doc.url} target="_blank" rel="noreferrer">
                        {doc.label}
                      </a>
                    ))
                  }
                </div>
              </article>
            ))
          }
        </div>

        <p class="empty" id="empty-state" hidden>No matching Scout records.</p>
      </section>
    </main>

    <footer>Raised by Raggle</footer>

    <script>
      const cards = [...document.querySelectorAll(".catalog-card")];
      const filters = [...document.querySelectorAll(".filter")];
      const input = document.querySelector("#search");
      const empty = document.querySelector("#empty-state");
      let activeCollection = "all";

      const applyFilters = () => {
        const query = input.value.trim().toLowerCase();
        let visible = 0;

        for (const card of cards) {
          const matchesCollection =
            activeCollection === "all" || card.dataset.collection === activeCollection;
          const matchesSearch = !query || card.dataset.search.includes(query);
          const matched = matchesCollection && matchesSearch;

          card.hidden = !matched;
          if (matched) visible += 1;
        }

        empty.hidden = visible !== 0;
      };

      for (const filter of filters) {
        filter.addEventListener("click", () => {
          activeCollection = filter.dataset.collection;

          for (const item of filters) {
            item.classList.toggle("is-active", item === filter);
          }

          applyFilters();
        });
      }

      input.addEventListener("input", applyFilters);
    </script>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --ink: #17202a;
    --muted: #56616f;
    --paper: #f7f8f4;
    --surface: #ffffff;
    --line: #d7ddd3;
    --green: #236b4f;
    --blue: #315f9f;
    --gold: #c79b28;
    --shadow: rgba(23, 32, 42, 0.08);
  }

  * {
    box-sizing: border-box;
  }

  html {
    width: 100%;
    overflow-x: hidden;
  }

  body {
    display: grid;
    grid-template-rows: auto 1fr auto;
    width: 100%;
    max-width: 100vw;
    min-height: 100vh;
    margin: 0;
    overflow-x: hidden;
    background: var(--paper);
    color: var(--ink);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .topbar {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    min-height: 76px;
    padding: 14px 22px;
    border-bottom: 1px solid var(--line);
    background: rgba(247, 248, 244, 0.92);
    backdrop-filter: blur(14px);
  }

  .brand {
    display: flex;
    min-width: 0;
    align-items: center;
    gap: 12px;
  }

  .brand-mark {
    display: grid;
    width: 42px;
    height: 42px;
    flex: 0 0 42px;
    place-items: center;
    border: 1px solid rgba(35, 107, 79, 0.32);
    border-radius: 8px;
    background: #e7f2eb;
    color: var(--green);
    font-weight: 900;
  }

  .brand strong,
  .brand small {
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .brand strong {
    font-size: 1.2rem;
    line-height: 1.15;
  }

  .brand small {
    margin-top: 3px;
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .actions {
    display: flex;
    flex-shrink: 0;
    gap: 10px;
  }

  .actions a,
  .card-actions a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    min-height: 38px;
    padding: 0 12px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
    color: var(--ink);
    font-size: 0.88rem;
    font-weight: 850;
  }

  .actions a:hover,
  .actions a:focus-visible,
  .card-actions a:hover,
  .card-actions a:focus-visible {
    border-color: rgba(49, 95, 159, 0.42);
    color: var(--blue);
    outline: 0;
  }

  main,
  footer {
    width: calc(100vw - 24px);
    max-width: 1160px;
    margin: 0 auto;
  }

  main {
    padding: 28px 0 44px;
  }

  .intro {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 24px;
    align-items: end;
    padding: 6px 0 26px;
  }

  h1,
  h2,
  h3,
  p,
  dl {
    margin: 0;
  }

  h1 {
    max-width: 780px;
    font-size: clamp(2.4rem, 7vw, 5.2rem);
    line-height: 0.98;
    letter-spacing: 0;
  }

  .intro p {
    max-width: 720px;
    margin-top: 14px;
    color: var(--muted);
    font-size: 1.08rem;
    font-weight: 650;
    line-height: 1.55;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(84px, 1fr));
    gap: 8px;
  }

  .stats div {
    min-width: 88px;
    padding: 12px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
    box-shadow: 0 10px 28px var(--shadow);
  }

  .stats dt {
    color: var(--green);
    font-size: 1.28rem;
    font-weight: 950;
    line-height: 1;
  }

  .stats dd {
    margin: 5px 0 0;
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 850;
  }

  .directory {
    padding-top: 4px;
  }

  .directory-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(240px, 420px);
    gap: 16px;
    align-items: end;
    margin-bottom: 14px;
  }

  h2 {
    font-size: 1.22rem;
    line-height: 1.2;
  }

  .search {
    display: grid;
    gap: 6px;
  }

  .search span,
  .eyebrow {
    color: var(--muted);
    font-size: 0.74rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .search input {
    width: 100%;
    min-height: 42px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
    color: var(--ink);
    font: inherit;
    font-size: 0.96rem;
    font-weight: 650;
    outline: 0;
    padding: 0 12px;
  }

  .search input:focus {
    border-color: rgba(49, 95, 159, 0.56);
    box-shadow: 0 0 0 3px rgba(49, 95, 159, 0.12);
  }

  .filters {
    display: flex;
    gap: 8px;
    margin: 0 0 18px;
    padding: 0 0 4px;
    overflow-x: auto;
    scrollbar-width: thin;
  }

  .filter {
    display: inline-flex;
    flex: 0 0 auto;
    align-items: center;
    gap: 8px;
    min-height: 36px;
    padding: 0 12px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
    color: var(--muted);
    cursor: pointer;
    font: inherit;
    font-size: 0.88rem;
    font-weight: 900;
  }

  .filter span {
    color: var(--gold);
  }

  .filter:hover,
  .filter:focus-visible,
  .filter.is-active {
    border-color: rgba(35, 107, 79, 0.5);
    background: var(--green);
    color: #ffffff;
    outline: 0;
  }

  .filter:hover span,
  .filter:focus-visible span,
  .filter.is-active span {
    color: #ffffff;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .catalog-card {
    display: flex;
    min-height: 214px;
    flex-direction: column;
    gap: 14px;
    padding: 16px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
    box-shadow: 0 10px 28px var(--shadow);
  }

  .card-main {
    display: grid;
    grid-template-columns: 42px minmax(0, 1fr);
    gap: 12px;
    align-items: start;
  }

  .card-main img {
    width: 42px;
    height: 42px;
    padding: 6px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #f4f6f7;
    object-fit: contain;
  }

  h3 {
    overflow: hidden;
    margin-top: 3px;
    font-size: 1.04rem;
    line-height: 1.22;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .card-main p {
    overflow: hidden;
    margin-top: 5px;
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 720;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .chips li {
    padding: 5px 8px;
    border: 1px solid #dce6ec;
    border-radius: 8px;
    background: #f2f8fb;
    color: var(--blue);
    font-size: 0.76rem;
    font-weight: 900;
  }

  .template-list {
    display: grid;
    gap: 8px;
  }

  .template-item {
    display: grid;
    gap: 6px;
    padding: 10px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fbfcf8;
  }

  .template-item span {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 900;
  }

  .template-item small {
    color: var(--blue);
    font-size: 0.72rem;
    font-weight: 900;
  }

  code {
    overflow-wrap: anywhere;
    color: var(--ink);
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
    font-size: 0.78rem;
    font-weight: 750;
  }

  .template-item dl {
    display: grid;
    grid-template-columns: minmax(70px, auto) minmax(0, 1fr);
    gap: 4px 8px;
    color: var(--muted);
    font-size: 0.76rem;
    font-weight: 760;
  }

  .template-item dd {
    margin: 0;
    overflow-wrap: anywhere;
  }

  .template-item dd small {
    margin-left: 6px;
  }

  .card-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: auto;
  }

  .card-actions svg {
    width: 16px;
    height: 16px;
  }

  .empty {
    margin: 0;
    padding: 30px 0;
    color: var(--muted);
    font-weight: 850;
  }

  footer {
    padding: 20px 0 28px;
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 900;
  }

  @media (max-width: 920px) {
    .intro,
    .directory-head {
      grid-template-columns: 1fr;
    }

    .stats,
    .grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 680px) {
    .topbar {
      position: static;
      align-items: stretch;
      flex-direction: column;
      gap: 14px;
      padding: 16px;
    }

    .brand {
      align-items: flex-start;
    }

    .brand small {
      white-space: normal;
    }

    .actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    main,
    footer {
      width: calc(100vw - 28px);
    }

    main {
      padding-top: 22px;
    }

    h1 {
      font-size: 2.4rem;
    }

    .intro p {
      font-size: 1rem;
    }

    .stats,
    .grid {
      grid-template-columns: 1fr;
    }

    .stats {
      display: flex;
      overflow-x: auto;
      padding-bottom: 4px;
    }

    .stats div {
      flex: 1 0 112px;
    }
  }

  @media (max-width: 430px) {
    .actions {
      grid-template-columns: 1fr;
    }

    .actions a,
    .card-actions a {
      width: 100%;
    }

    .catalog-card {
      padding: 14px;
    }
  }
</style>
