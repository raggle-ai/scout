{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Raggle Scout Credential Link",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "slug", "url", "category", "domain"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "url": { "type": "string", "format": "uri" },
    "category": { "type": "string", "minLength": 1 },
    "domain": { "type": "string", "minLength": 1 },
    "variables": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "label"],
        "properties": {
          "key": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "placeholder": { "type": "string" }
        }
      }
    },
    "credentialUrls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "kind", "url", "domain"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "kind": {
            "enum": [
              "api-key",
              "oauth-app",
              "access-token",
              "webhook-secret",
              "service-account",
              "dashboard",
              "docs"
            ]
          },
          "url": { "type": "string", "format": "uri" },
          "domain": { "type": "string", "minLength": 1 },
          "variables": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["key", "label"],
              "properties": {
                "key": { "type": "string", "minLength": 1 },
                "label": { "type": "string", "minLength": 1 },
                "placeholder": { "type": "string" },
                "format": { "enum": ["absolute-path", "uuid", "slug", "string"] },
                "encoding": { "enum": ["none", "url-component"] }
              }
            }
          }
        }
      }
    }
  }
}
